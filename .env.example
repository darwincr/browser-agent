OPENCODE_A2A_VERSION=1.1.1

A2A_HOST_PORT=18000
OPENCODE_HOST_PORT=14096
VNC_HOST_PORT=5900
NOVNC_HOST_PORT=6080

A2A_PUBLIC_URL=http://localhost:18000
OPENCODE_HOST=0.0.0.0
OPENCODE_WORKSPACE_ROOT=/workspace
A2A_STATIC_AUTH_CREDENTIALS=[{"scheme":"bearer","token":"change-me","principal":"local"}]

# Set this to require a VNC password. If omitted, VNC runs without a password.
# VNC_PASSWORD=change-me-too
