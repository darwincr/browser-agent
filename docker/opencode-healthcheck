#!/usr/bin/env bash
set -euo pipefail

url="http://127.0.0.1:${OPENCODE_PORT:-4096}/global/health"
curl_args=(--fail --silent --show-error --max-time "${HEALTHCHECK_TIMEOUT_SECONDS:-5}")

if [ -n "${OPENCODE_SERVER_PASSWORD:-}" ]; then
  curl_args+=(--user "${OPENCODE_SERVER_USERNAME:-opencode}:${OPENCODE_SERVER_PASSWORD}")
fi

response="$(curl "${curl_args[@]}" "$url")"

python -c '
import json
import sys

try:
    data = json.load(sys.stdin)
except json.JSONDecodeError:
    sys.exit(1)

sys.exit(0 if data.get("healthy") is True else 1)
' <<<"$response"
