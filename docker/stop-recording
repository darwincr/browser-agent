#!/usr/bin/env bash
set -euo pipefail

work_dir="$(pwd)"
pid_file="${SCREEN_RECORDING_PID_FILE:-${work_dir}/screen-recording.pid}"

if [ ! -f "$pid_file" ]; then
  printf 'No active screen recording found.\n' >&2
  exit 1
fi

recording_pid="$(cat "$pid_file" 2>/dev/null || true)"
output_file="$(cat "${pid_file}.output" 2>/dev/null || true)"

if [ -z "$recording_pid" ] || ! kill -0 "$recording_pid" 2>/dev/null; then
  rm -f "$pid_file" "${pid_file}.output"
  printf 'No active screen recording process found.\n' >&2
  exit 1
fi

# SIGINT lets ffmpeg finalize the MP4 container cleanly.
kill -INT "$recording_pid"

for _ in $(seq 1 50); do
  if ! kill -0 "$recording_pid" 2>/dev/null; then
    break
  fi
  sleep 0.1
done

if kill -0 "$recording_pid" 2>/dev/null; then
  printf 'Recording did not stop after SIGINT; sending SIGTERM.\n' >&2
  kill -TERM "$recording_pid" 2>/dev/null || true
fi

rm -f "$pid_file" "${pid_file}.output"

printf 'Stopped screen recording.\n'
if [ -n "$output_file" ]; then
  printf 'Output: %s\n' "$output_file"
fi
