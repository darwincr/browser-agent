{
  "$schema": "https://opencode.ai/config.json",
  "server": {
    "port": 4096,
    "hostname": "0.0.0.0",
    "cors": [
      "dranzone.net",
      "http://localhost:4096"
    ]
  },
  "plugin": [
    "@tarquinen/opencode-smart-title"
  ],
  "default_agent": "Build",
  "small_model": "dr-openai/CLIProxy/gemini-3.1-flash-lite",
  "autoupdate": true,
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 8192
  },
  "command": {
    "test": {
      "template": "Run tests for the modified files and suggest fixes for any failures.",
      "description": "Run tests for the modified files and suggest fixes for any failures."
    }
  },
  "mcp": {
    "web_search_prime": {
      "type": "remote",
      "enabled": false,
      "url": "https://litellm.dranzone.net/web_search_prime/mcp",
      "headers": {
        "x-litellm-api-key": "Bearer {env:LITELLM_API_KEY}"
      }
    },
    "zread": {
      "type": "remote",
      "enabled": false,
      "url": "https://litellm.dranzone.net/zread/mcp",
      "headers": {
        "x-litellm-api-key": "Bearer {env:LITELLM_API_KEY}"
      }
    },
    "docs-langchain": {
      "type": "remote",
      "enabled": false,
      "url": "https://docs.langchain.com/mcp"
    }
  },
