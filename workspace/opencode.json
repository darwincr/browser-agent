  "permission": {
    "skill": {
      "customize-opencode": "deny"
    }
  },
  "agent": {
    "Build": {
      "mode": "primary",
      "description": "Build",
      "model": "dr-openai/zai/glm-5.2",
      "temperature": 1,
      "permission": {
        "bash": {
          "git push": "ask",
          "*": "allow"
        },
        "edit": "allow"
      },
      "options": {}
    },
    "Build1": {
      "mode": "primary",
      "description": "Build 1",
      "model": "dr-openai/cockpit/gpt-5.5",
      "temperature": 1,
      "permission": {
        "bash": {
          "git push": "ask",
          "*": "allow"
        },
        "edit": "allow"
      },
      "options": {}
    },
    "Build3": {
      "mode": "primary",
      "description": "Build 3",
      "model": "dr-openai/omlx/Qwen3.6-27B-oQ8-fp16-mtp",
      "temperature": 0.1,
      "permission": {
        "bash": {
          "git push": "ask",
          "*": "allow"
        },
        "edit": "allow"
      },
      "options": {}
    },
    "plan": {
      "mode": "primary",
      "description": "Planning agent - GLM5.2",
      "model": "dr-openai/zai/glm-5.2",
      "temperature": 1,
      "tools": {
        "write": false,
        "edit": false,
        "bash": false
      },
      "options": {},
      "permission": {
        "edit": "deny",
        "bash": "deny"
      }
    },
    "general": {
      "mode": "subagent",
      "description": "Deep reasoning and research",
      "model": "dr-openai/zai/glm-5.2",
      "variant": "none",
      "temperature": 1,
      "maxSteps": 10,
      "options": {},
      "permission": {},
      "steps": 10
    },
    "explore": {
      "mode": "subagent",
      "description": "Fast codebase exploration",
      "model": "dr-openai/zai/glm-5.2",
      "variant": "none",
      "temperature": 1,
      "tools": {
        "webfetch": false
      },
      "options": {},
      "permission": {
